# ───────────────────────────────────────────────
#  Fradema Automação — .gitignore
# ───────────────────────────────────────────────

# ─── Segredos / credenciais (NUNCA versionar) ───
.env
.env.*
!.env.example

# ─── Sessão do WhatsApp / Baileys (credenciais do número) ───
# Vazar isto = dar acesso ao WhatsApp conectado. Jamais commitar.
auth/
mvp/auth/
creds.json
app-state-sync-*.json
session-*.json
pre-key-*.json
sender-key-*.json

# ─── Dados de runtime (leads = dados pessoais / LGPD) ───
mvp/data/
data/leads.json
mvp/n8n-data/
n8n-data/

# ─── Node ───
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/

# ─── Logs ───
*.log
logs/

# ─── Sistema operacional ───
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# ─── Editores / IDEs ───
.vscode/
.idea/
*.swp
*.swo
*~
