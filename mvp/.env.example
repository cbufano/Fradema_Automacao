# Copie para .env e preencha.
# Chave da API do Claude (obrigatória para a qualificação com IA)
ANTHROPIC_API_KEY=coloque-sua-chave-aqui

# Modelo (opcional). Padrão: claude-sonnet-5 (rápido e barato para o bot).
# Para respostas mais fortes: claude-opus-4-8
CLAUDE_MODEL=claude-sonnet-5

# Porta do painel (opcional)
PORT=5100

# Webhook do n8n avisado quando um lead vira "quente" (opcional).
# No docker-compose, aponte para o seu workflow, ex.: http://n8n:5678/webhook/lead-quente
N8N_WEBHOOK_URL=

# Token opcional para proteger /api/send e /api/outbound.
# Se definido, exige "Authorization: Bearer <token>" (o n8n envia o mesmo).
API_TOKEN=

# Chave de cifragem das credenciais do n8n (recomendada em produção).
# Gere uma aleatória, ex.: openssl rand -hex 24
N8N_ENCRYPTION_KEY=
